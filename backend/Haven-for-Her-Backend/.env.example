# === ASP.NET Core ===
ASPNETCORE_ENVIRONMENT=Development

# === Database (PostgreSQL — required for dev and prod) ===
ConnectionStrings__HavenForHerBackendAuthConnection=Host=localhost;Port=5432;Database=HavenForHer;Username=postgres;Password=postgres
ConnectionStrings__HavenForHerBackendIdentityConnection=Host=localhost;Port=5432;Database=HavenForHerAuth;Username=postgres;Password=postgres

# === Google OAuth (required for Sign in with Google; get values from Google Cloud Console) ===
# Load via: copy this file to `.env` and use a tool that injects env vars, OR use `dotnet user-secrets` (recommended).
#   dotnet user-secrets set "Authentication:Google:ClientId" "YOUR_ID"
#   dotnet user-secrets set "Authentication:Google:ClientSecret" "YOUR_SECRET"
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

# === Frontend URL(s) for CORS — must match the Vite dev URL (HTTPS + mkcert in this repo) ===
FrontendUrl=https://localhost:5173

# === Default Admin Account (seeded on startup) ===
GenerateDefaultIdentityAdmin__Email=admin@havenforher.local
GenerateDefaultIdentityAdmin__Password=admin!haven4her

# === Meta / Facebook / Instagram Ads API ===
# System User token from Meta Business Manager (long-lived, no user login needed)
META_SYSTEM_USER_TOKEN=
# Ad account ID (numeric, no "act_" prefix — the backend adds that)
META_AD_ACCOUNT_ID=1219500792320453
# Facebook Page ID the ads are published through
META_PAGE_ID=1101772009681644
META_IG_USER_ID=
# App credentials (from Meta for Developers dashboard)
META_APP_ID=26373965655592772
META_APP_SECRET=
# Graph API version
META_GRAPH_API_VERSION=v20.0

# === TikTok API ===
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
