# === ASP.NET Core ===
ASPNETCORE_ENVIRONMENT=Development

# === Database (SQLite for dev, PostgreSQL for production) ===
# ConnectionStrings__HavenForHerBackendAuthConnection=Data Source=HavenForHerBackendAuthConnection.sqlite
# ConnectionStrings__HavenForHerBackendIdentityConnection=Data Source=HavenForHerBackendIdentityConnection.sqlite

# === Google OAuth ===
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

# === Frontend URL(s) for CORS (comma-separated) ===
FrontendUrl=http://localhost:5173

# === Default Admin Account (seeded on startup) ===
GenerateDefaultIdentityAdmin__Email=admin@rootkit.local
GenerateDefaultIdentityAdmin__Password=Rootkit2026!Admin

# === Meta / Facebook / Instagram API ===
META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_IG_USER_ID=

# === TikTok API ===
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
